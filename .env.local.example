# =============================================================================
# DEVELOPMENT SETUP (Docker Compose)
# =============================================================================
# For local development, use Docker Compose PostgreSQL:
# - Start: docker-compose up -d postgres
# - Migrate: pnpm db:migrate
# - Seed: pnpm db:seed

# Database (Local Docker)
DATABASE_URL=postgresql://postgres:password@localhost:5432/freshflow

# =============================================================================
# PRODUCTION SETUP (Supabase)
# =============================================================================
# For production, use Supabase's managed PostgreSQL:
# - Create project at https://supabase.com/dashboard
# - Get connection string from Project Settings → Database
# - Replace DATABASE_URL with Supabase connection string:
#   DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase (Auth + Database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# =============================================================================
# REDIS CACHE (Optional - falls back to in-memory)
# =============================================================================
# For local development with Docker:
# docker run -d --name redis -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECURITY & CORS
# =============================================================================
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# WHATSAPP INTEGRATION (Optional - Twilio)
# =============================================================================
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_DEFAULT_PHONE=+5511999999999

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_API_URL=http://localhost:3001
