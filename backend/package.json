{
  "name": "freshflow-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp src/docs/openapi.yaml dist/docs/openapi.yaml",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "vitest",
    "test:unit": "vitest run src/__tests__",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.39.7",
    "@trpc/server": "^11.0.0-rc.553",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jose": "^5.2.2",
    "js-yaml": "^4.1.1",
    "pdfkit": "^0.15.0",
    "redis": "^4.6.13",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.13",
    "@types/pdfkit": "^0.13.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
